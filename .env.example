# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/abundantlife

# (Optional) Comma-separated allowed CORS origins for production
# CORS_ORIGIN=https://your-app.up.railway.app

# (Optional) For native app builds - the production API URL
# EXPO_PUBLIC_API_URL=https://your-app.up.railway.app

# (Optional) For static Expo build - the production domain
# APP_DOMAIN=your-app.up.railway.app
